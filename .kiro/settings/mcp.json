{
  "mcpServers": {
    "firebase": {
      "command": "npx",
      "args": [
        "-y",
        "firebase-tools@latest",
        "experimental:mcp"
      ],
      "env": {
        "FIREBASE_PROJECT": "desabafo-anonimo-ifal"
      },
      "disabled": false,
      "autoApprove": [
        "firebase_get_security_rules",
        "firebase_list_apps",
        "firebase_validate_security_rules"
      ]
    }
  }
}